rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userRole() {
      return userDoc().role;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userRole() == 'admin';
    }
    
    function isStaff() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userRole() in ['admin', 'manager', 'cashier', 'accountant'];
    }
    
    function isManagerOrAdmin() {
      return isAdmin() || (isAuthenticated() && userRole() == 'manager');
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    // User Profiles
    match /users/{userId} {
      // Allow read for authenticated users (own profile only) or staff
      allow read: if isOwner(userId) || isStaff();
      // Allow create for doctors (self-registration) and admins (staff creation)
      allow create: if isAuthenticated() && isOwner(userId) && 
                      request.resource.data.role == 'doctor' && 
                      request.resource.data.status == 'pending';
      // Allow admin to create staff accounts
      allow create: if isAdmin() && 
                      request.resource.data.role in ['admin', 'manager', 'cashier', 'accountant'];
      // Allow update for password changes and profile updates
      allow update: if isAdmin() || (isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['password', 'lastLoginAt']));
      // Allow delete for admins only
      allow delete: if isAdmin();
    }
    
    // Allow list queries for staff authentication (email lookup only)
    // This is necessary for staff login since we can't use Cloud Functions without billing
    match /users {
      allow list: if true;
    }
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isManagerOrAdmin();
      allow update: if isManagerOrAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
        request.resource.data.stock < resource.data.stock &&
        request.resource.data.stock >= 0
      );
    }
    
    // Orders
    match /orders/{orderId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || userRole() == 'accountant' || userRole() == 'cashier' || userRole() == 'manager' || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();
    }
    
    // Payments
    match /payments/{paymentId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isStaff() || (isAuthenticated() && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == 'admin'));
      allow update: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Favorites
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Product Returns
    match /returns/{returnId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }
    
    // Promotions
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    
    // Expenses
    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin() || userRole() == 'accountant';
    }
    
    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }
    
    // Shop Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isManagerOrAdmin() || (settingId == 'backup_meta' && isStaff());
    }
  }
}
