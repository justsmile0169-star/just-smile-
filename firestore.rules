rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userRole() {
      return userDoc().role;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userRole() == 'admin';
    }
    
    function isStaff() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userRole() in ['admin', 'manager', 'cashier', 'accountant'];
    }
    
    function isManagerOrAdmin() {
      return isAdmin() || (isAuthenticated() && userRole() == 'manager');
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    // User Profiles
    match /users/{userId} {
      // Allow read for login purposes (staff authentication)
      allow read, write: if true;
    }
    
    // Allow list queries for staff authentication
    match /users {
      allow list, get: if true;
    }
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isManagerOrAdmin();
      allow update: if isManagerOrAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
        request.resource.data.stock < resource.data.stock &&
        request.resource.data.stock >= 0
      );
    }
    
    // Orders
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    // Payments
    match /payments/{paymentId} {
      allow read, write: if true;
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    // Favorites
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Product Returns
    match /returns/{returnId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }
    
    // Promotions
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    
    // Expenses
    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin() || userRole() == 'accountant';
    }
    
    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }
    
    // Shop Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isManagerOrAdmin() || (settingId == 'backup_meta' && isStaff());
    }
  }
}
