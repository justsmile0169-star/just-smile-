rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user document exists
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Get user document data safely
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Get user role safely
    function userRole() {
      return userExists() ? userDoc().role : null;
    }

    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() && userExists() && userRole() == 'admin';
    }

    // Check if user is staff
    function isStaff() {
      return isAuthenticated() && userExists() && userRole() in ['admin', 'manager', 'cashier', 'accountant'];
    }

    function isManagerOrAdmin() {
      return isAdmin() || (isAuthenticated() && userExists() && userRole() == 'manager');
    }

    // User Profiles
    match /users/{userId} {
      // Allow get for authenticated users (own profile only) or staff
      allow get: if isStaff() || (isAuthenticated() && request.auth.uid == userId);
      // Allow list queries for all users (needed for login system)
      allow list: if true;
      // Allow create for doctors (self-registration) and admins (staff creation)
      allow create: if isAuthenticated() && request.auth.uid == userId &&
                      request.resource.data.role == 'doctor' &&
                      request.resource.data.status == 'pending';
      // Allow admin to create staff accounts
      allow create: if isAdmin() &&
                      request.resource.data.role in ['admin', 'manager', 'cashier', 'accountant'];
      // Allow update for password changes and profile updates
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      // Allow delete for admins only
      allow delete: if isAdmin();
      // ── Bootstrap: allow setting password for accounts that have none yet ──
      // This allows the first-time admin setup without authentication.
      // Only allows updating the single 'password' field when it doesn't exist.
      allow update: if !('password' in resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['password']) &&
                      request.resource.data.password is string &&
                      request.resource.data.password.size() > 20;
    }
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isManagerOrAdmin();
      allow update: if isManagerOrAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
        request.resource.data.stock < resource.data.stock &&
        request.resource.data.stock >= 0
      );
    }
    
    // Orders
    match /orders/{orderId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || userRole() == 'accountant' || userRole() == 'cashier' || userRole() == 'manager' || (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }
    
    // Payments
    match /payments/{paymentId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isStaff() || (isAuthenticated() && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == 'admin'));
      allow update: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Favorites
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // Product Returns
    match /returns/{returnId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }
    
    // Promotions
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isManagerOrAdmin();
    }
    
    // Expenses
    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow write: if isManagerOrAdmin() || userRole() == 'accountant';
    }
    
    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }
    
    // Shop Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isManagerOrAdmin() || (settingId == 'backup_meta' && isStaff());
    }

    // Admin Messages (doctor to admin communication)
    match /admin_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && userExists() && userRole() == 'doctor';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Announcements / Ads (visible to all, writable by manager+)
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isManagerOrAdmin() || (isAuthenticated() && userExists() && userRole() == 'cashier');
    }
  }
}
